---
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<div class="mock-titlebar">
  <div class="mock-dot"></div>
  <div class="mock-dot"></div>
  <div class="mock-dot"></div>
  <span class="mock-titlebar-text">{title}</span>
</div>

<style>
  .mock-titlebar {
    display: flex; align-items: center; gap: 6px;
    padding: 12px 16px; border-bottom: 1px solid rgba(255,255,255,0.06);
  }
  .mock-dot { width: 8px; height: 8px; border-radius: 50%; background: var(--gray-700); }
  .mock-titlebar-text {
    font-family: var(--mono); font-size: 11px; color: var(--gray-500);
    margin-left: 8px; letter-spacing: 0.5px;
  }
</style>
