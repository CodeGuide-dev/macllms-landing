---
interface Props {
  title: string;
  description: string;
  iconSvg: string;
}

const { title, description, iconSvg } = Astro.props;
---

<div class="feature-card reveal">
  <div class="feature-icon-wrap">
    <Fragment set:html={iconSvg} />
  </div>
  <h3>{title}</h3>
  <p>{description}</p>
</div>

<style>
  .feature-card {
    background: var(--black); padding: 40px 32px;
    transition: transform 0.5s ease, background 0.3s ease, box-shadow 0.3s ease, opacity 0.8s ease, border-top-color 0.3s ease;
    border-top: 2px solid rgba(255,255,255,0.08); position: relative;
  }
  .feature-card:hover {
    background: var(--gray-900); transform: translateY(-3px);
    box-shadow: 0 8px 32px rgba(0,0,0,0.4); border-top-color: var(--white);
  }
  .feature-icon-wrap {
    width: 44px; height: 44px; border: 1px solid rgba(255,255,255,0.12);
    border-radius: 50%; display: flex; align-items: center; justify-content: center;
    margin-bottom: 20px; transition: border-color 0.3s;
  }
  .feature-card:hover .feature-icon-wrap { border-color: rgba(255,255,255,0.3); }
  .feature-icon-wrap :global(svg) { width: 20px; height: 20px; }
  h3 { font-family: var(--heading); font-size: 22px; font-weight: 500; margin-bottom: 10px; letter-spacing: 0.2px; }
  p { font-size: 14px; color: var(--gray-400); line-height: 1.7; }
</style>
