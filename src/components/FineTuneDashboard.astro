---
import MockTitlebar from './MockTitlebar.astro';
---

<div class="mock-dashboard">
  <MockTitlebar title="Fine-Tune Studio" />
  <div class="mock-body">
    <div class="mock-model-select">
      <span>Qwen 3.5 &#8212; 4B &#8212; Q4_K_M</span>
      <span class="arrow">&#9660;</span>
    </div>
    <div class="mock-status">
      <div class="mock-status-dot"></div>
      <span>Training &#183; Epoch 7 of 10</span>
    </div>
    <div class="mock-row">
      <div class="mock-card">
        <div class="mock-card-label">Train Loss</div>
        <div class="mock-card-value">0.847</div>
        <div class="mock-card-sub">&#8595; 42% from start</div>
      </div>
      <div class="mock-card">
        <div class="mock-card-label">Eval Loss</div>
        <div class="mock-card-value">0.913</div>
        <div class="mock-card-sub">&#8595; 38% from start</div>
      </div>
      <div class="mock-card">
        <div class="mock-card-label">Learning Rate</div>
        <div class="mock-card-value small">2e-4</div>
        <div class="mock-card-sub">Cosine schedule</div>
      </div>
    </div>
    <div class="mock-chart">
      <div class="mock-chart-label">Loss Curve</div>
      <svg viewBox="0 0 300 60" preserveAspectRatio="none">
        <polyline fill="none" stroke="rgba(255,255,255,0.15)" stroke-width="1" points="0,55 30,52 60,45 90,38 120,30 150,25 180,20 210,16 240,13 270,11 300,10" />
        <polyline fill="none" stroke="white" stroke-width="1.5" points="0,58 30,50 60,42 90,33 120,26 150,21 180,17 210,14 240,11 270,9 300,8" />
      </svg>
    </div>
    <div class="mock-progress-wrap">
      <div class="mock-progress-top">
        <span>Overall Progress</span>
        <span>73%</span>
      </div>
      <div class="mock-progress-bar">
        <div class="mock-progress-fill"></div>
      </div>
    </div>
  </div>
</div>

<style>
  .mock-dashboard { border: 1px solid rgba(255,255,255,0.1); background: var(--gray-900); overflow: hidden; }
  .mock-body { padding: 24px; }
  .mock-model-select {
    border: 1px solid rgba(255,255,255,0.1); padding: 10px 14px;
    display: flex; justify-content: space-between; align-items: center;
    margin-bottom: 16px; background: var(--black);
  }
  .mock-model-select span { font-family: var(--mono); font-size: 12px; color: var(--white); }
  .mock-model-select .arrow { font-size: 10px; color: var(--gray-500); }
  .mock-status { display: flex; align-items: center; gap: 8px; margin-bottom: 20px; }
  .mock-status-dot {
    width: 8px; height: 8px; border-radius: 50%;
    background: var(--white); animation: pulse-dot 2s ease-in-out infinite;
  }
  .mock-status span {
    font-family: var(--mono); font-size: 11px; color: var(--gray-400);
    letter-spacing: 1px; text-transform: uppercase;
  }
  .mock-row { display: flex; gap: 16px; margin-bottom: 16px; }
  .mock-card {
    flex: 1; border: 1px solid rgba(255,255,255,0.06);
    padding: 16px; background: var(--black);
  }
  .mock-card-label {
    font-family: var(--mono); font-size: 9px; letter-spacing: 2px;
    text-transform: uppercase; color: var(--gray-600); margin-bottom: 8px;
  }
  .mock-card-value { font-family: var(--heading); font-size: 28px; font-weight: 500; color: var(--white); }
  .mock-card-value.small { font-size: 18px; }
  .mock-card-sub { font-family: var(--mono); font-size: 10px; color: var(--gray-500); margin-top: 4px; }
  .mock-chart {
    height: 100px; border: 1px solid rgba(255,255,255,0.06);
    background: var(--black); padding: 12px; position: relative; overflow: hidden;
  }
  .mock-chart-label {
    font-family: var(--mono); font-size: 9px; letter-spacing: 2px;
    text-transform: uppercase; color: var(--gray-600);
    position: absolute; top: 8px; left: 12px;
  }
  .mock-chart svg {
    position: absolute; bottom: 8px; left: 12px; right: 12px;
    width: calc(100% - 24px); height: 60px;
  }
  .mock-progress-wrap { margin-top: 16px; }
  .mock-progress-top { display: flex; justify-content: space-between; margin-bottom: 6px; }
  .mock-progress-top span {
    font-family: var(--mono); font-size: 10px; color: var(--gray-500);
    letter-spacing: 1px; text-transform: uppercase;
  }
  .mock-progress-bar { height: 4px; background: var(--gray-800); overflow: hidden; }
  .mock-progress-fill {
    height: 100%; background: var(--white); width: 73%;
    animation: progress-anim 4s ease-in-out infinite;
  }
  @media (max-width: 900px) {
    .mock-row { flex-direction: column; }
  }
</style>
